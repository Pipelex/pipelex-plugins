{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.mthds)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-mthds.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Write(*.mthds)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-mthds.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
